// tcpconnlat.bt — TCP connect latency histogram, microseconds.
//
// Times the gap between tcp_v4_connect entry and return. Captures both
// successful and failed connects; nothing filters EAGAIN/in-progress.

BEGIN {
  printf("Tracing TCP connect latency. Hit Ctrl-C to summarise.\n");
}

kprobe:tcp_v4_connect {
  @start[pid] = nsecs;
}

kretprobe:tcp_v4_connect /@start[pid]/ {
  $delta = nsecs - @start[pid];
  @usecs = hist($delta / 1000);
  delete(@start[pid]);
}
