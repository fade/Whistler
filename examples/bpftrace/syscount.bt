// syscount.bt — count syscalls by pid.
//
// Uses the generic raw_syscalls/sys_enter tracepoint, which fires once
// per syscall regardless of which one. Result: top syscalling pids.

BEGIN {
  printf("Counting syscalls per pid. Hit Ctrl-C to summarise.\n");
}

tracepoint:raw_syscalls:sys_enter {
  @[pid]++;
}
