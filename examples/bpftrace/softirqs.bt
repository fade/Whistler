// softirqs.bt — count software interrupts by vector.
//
// Each softirq vector (0 = HI, 1 = TIMER, 2 = NET_TX, 3 = NET_RX,
// 4 = BLOCK, 5 = IRQ_POLL, 6 = TASKLET, 7 = SCHED, 8 = HRTIMER, 9 = RCU)
// gets its own bucket.

BEGIN {
  printf("Counting softirqs by vector. Hit Ctrl-C to summarise.\n");
}

tracepoint:irq:softirq_entry {
  @[args->vec]++;
}
